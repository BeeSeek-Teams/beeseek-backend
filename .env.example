# ─── App ──────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=beeseek
DB_PASSWORD=CHANGE_ME
DB_NAME=beeseek_db

# ─── Redis ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT / Auth ───────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_STRING
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Queen Bee Admin Key ─────────────────────────
QUEEN_BEE_PASSWORD=CHANGE_ME

# ─── Cloudinary (Image Uploads) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Monnify (Payments / Wallet) ─────────────────
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_SANDBOX_MODE=true

# ─── Email (SMTP) ────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
EMAIL_USER=no-reply@beeseek.site
EMAIL_PASS=

# ─── Firebase (Push Notifications) ───────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Termii (SMS / SOS) ─────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=BeeSeek
TERMII_BASE_URL=https://api.ng.termii.com

# ─── Google Maps ─────────────────────────────────
GOOGLE_MAPS_API_KEY=
